{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Mutsuki Service Control Request",
  "type": "object",
  "required": ["token", "method"],
  "properties": {
    "token": { "type": "string" },
    "method": {
      "type": "string",
      "enum": [
        "service_status",
        "service_shutdown",
        "core_status",
        "plugin_list",
        "plugin_reload",
        "plugin_call",
        "runner_list",
        "runner_restart",
        "runner_stop",
        "task_list",
        "task_cancel",
        "health_check",
        "log_tail"
      ]
    },
    "params": true
  },
  "$defs": {
    "pluginReloadResponse": {
      "type": "object",
      "required": [
        "previous_generation",
        "registry_generation",
        "plugin_count",
        "changes",
        "runner_errors"
      ],
      "properties": {
        "previous_generation": { "type": "integer", "minimum": 0 },
        "registry_generation": { "type": "integer", "minimum": 0 },
        "plugin_count": { "type": "integer", "minimum": 0 },
        "changes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["surface_id", "compatibility"],
            "properties": {
              "surface_id": { "type": "string" },
              "compatibility": {
                "type": "string",
                "enum": ["identical", "additive", "deprecated", "removed", "breaking"]
              }
            }
          }
        },
        "runner_errors": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
